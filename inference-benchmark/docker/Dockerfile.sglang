# =============================================================================
# inference-benchmark — SGLang image
#
# Build:
#   docker build -f docker/Dockerfile.sglang -t boothalgo01/bench-sglang:latest .
#
# Run:
#   docker run --gpus all \
#     -v /path/to/hf_cache:/root/.cache/huggingface \
#     -e BENCH_BRANCH=main \
#     -p 8000:8000 \
#     boothalgo01/bench-sglang:latest
# =============================================================================
FROM docker.io/lmsysorg/sglang:latest

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl vim openssh-server \
    && mkdir -p /run/sshd \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/bench_requirements.txt
RUN pip install -q -r /tmp/bench_requirements.txt

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/entrypoint.sh"]
